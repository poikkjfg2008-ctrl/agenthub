# AI Portal 环境配置示例
# 复制此文件为 .env 并修改相应的值

# ============= 服务器配置 =============
PORT=8000
HOST=0.0.0.0
RELOAD=true

# ============= 存储配置 =============
# 使用内存存储 (无需 Docker，默认)
USE_REDIS=false

# 使用 Redis 存储 (需要运行 docker-compose up -d)
# USE_REDIS=true
# REDIS_URL=redis://localhost:6379/0

# ============= JWT 配置 =============
JWT_SECRET=your-secret-key-change-in-production-use-strong-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============= OpenCode 配置 =============
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=your-opencode-password

# ============= OpenWork 配置 =============
OPENWORK_BASE_URL=http://127.0.0.1:8787
OPENWORK_TOKEN=your-openwork-token

# ============= Portal 配置 =============
PORTAL_NAME=AI Portal
RESOURCES_PATH=config/resources.json

# ============= 日志配置 =============
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG  # 开发时使用 DEBUG 级别

# ============= CORS 配置 =============
# 默认已配置本地开发地址，生产环境需要添加实际域名
# CORS_ORIGINS=http://localhost:5173,http://localhost:8000,https://your-domain.com

# ============= 前端配置 (frontend/.env) =============
# VITE_API_BASE_URL=http://localhost:8000
# VITE_APP_NAME=AI Portal
